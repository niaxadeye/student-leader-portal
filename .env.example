APP_ENV=development
APP_NAME=student-leader-cabinet
APP_BASE_URL=https://eazytech.ru
API_BASE_URL=https://eazytech.ru

HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# Порт 5433: системный PostgreSQL занимает 5432 на этом сервере
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_DB=student_leader
POSTGRES_USER=student_leader
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=disable

JWT_ISSUER=student-leader-cabinet
JWT_AUDIENCE=student-leader-web
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

COOKIE_DOMAIN=eazytech.ru
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=student-leader-files
S3_ACCESS_KEY=minio
S3_SECRET_KEY=change_me_minio
S3_USE_PATH_STYLE=true
S3_PRESIGN_TTL=15m

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_DEFAULT_THREAD_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

REDIS_URL=redis://127.0.0.1:6379/0

MAX_JSON_BODY_MB=2
DEFAULT_MAX_FILE_SIZE_MB=2048
DEFAULT_MAX_SUBMISSION_SIZE_MB=10240

LOG_LEVEL=info
OTEL_ENABLED=false
PROMETHEUS_ENABLED=true

FEATURE_REFERENCE_CMS=true
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_PARTICIPANT_CABINET=false
FEATURE_ATTENDANCE=false
FEATURE_POINTS=false
FEATURE_MERCH=false
FEATURE_PREDICTIONS=false
FEATURE_JURY=false

# Bootstrap superadmin — задаётся только при первом деплое, не коммитить реальные значения
BOOTSTRAP_SUPERADMIN_LOGIN=
BOOTSTRAP_SUPERADMIN_PASSWORD=
